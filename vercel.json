{
    "buildCommand": "npm run build",
    "builds": [
        {
            "src": "*.php",
            "use": "vercel-php@0.6.2"
        },
        {
            "src": "package.json",
            "use": "@vercel/static-build"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}