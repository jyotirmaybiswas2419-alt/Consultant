{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "builds": [
        {
            "src": "*.php",
            "use": "vercel-php@0.6.2"
        },
        {
            "src": "src/**",
            "use": "@vercel/static"
        },
        {
            "src": "dist/**",
            "use": "@vercel/static"
        }
    ]
}