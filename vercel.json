{
    "builds": [
        {
            "src": "*.php",
            "use": "vercel-php@0.6.2"
        },
        {
            "src": "dist/**",
            "use": "@vercel/static"
        },
        {
            "src": "src/assets/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/dist/(.*)",
            "dest": "/dist/$1"
        },
        {
            "src": "/src/assets/(.*)",
            "dest": "/src/assets/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}